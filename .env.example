# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── LLM API keys ──────────────────────────────────────────────────────────────
LANGEXTRACT_API_KEY=your_gemini_api_key_here       # required for Gemini fallback model

# ── Model selection ───────────────────────────────────────────────────────────
# Profile aliases are defined in MODEL_PROFILES (extractor/extraction.py).
# You can also pass a raw model ID (e.g. "gpt-oss:120b", "gemini-2.5-flash").
LLM_MODEL_PRIMARY=gpt-oss        # alias → gpt-oss:120b via Ollama cloud
LLM_MODEL_FALLBACK=gemini        # alias → gemini-2.5-flash (used if primary fails)

# ── Ollama cloud — primary model (GPT-OSS 120B) ───────────────────────────────
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=your_ollama_api_key_here
LLM_MAX_WORKERS_OLLAMA=1           # Ollama processes chunks sequentially (no parallelism)
LLM_MAX_CHAR_BUFFER_OLLAMA=30000   # large context window → full invoice in one chunk

# ── Gemini performance tuning — fallback model ────────────────────────────────
LLM_MAX_CHAR_BUFFER=4000           # chars per chunk (smaller keeps Gemini within rate limits)
LLM_MAX_WORKERS_GEMINI=10          # parallel chunk workers for Gemini

# ── Currency database (JSON array) ────────────────────────────────────────────
CURRENCY_DB_JSON=[{"code":"EUR","name":"Euro"},{"code":"USD","name":"US Dollar"},{"code":"RUB","name":"Russian Ruble"},{"code":"CNY","name":"Chinese Yuan"}]

# ── Database ──────────────────────────────────────────────────────────────────
# Omit DATABASE_URL to use SQLite (development only)
# DATABASE_URL=postgresql://user:password@localhost:5432/doc_extractor

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
