# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Model selection ────────────────────────────────────────────────────────────
# Profile aliases defined in MODEL_PROFILES (extractor/extraction.py):
#   "gpt-oss"   → gpt-oss:120b   (Ollama cloud)
#   "cerebras"  → gpt-oss-120b   (Cerebras cloud, ~3000 tok/s)
#   "gemini"    → gemini-2.5-flash
# You can also pass raw model IDs directly.
LLM_MODEL_PRIMARY=cerebras
LLM_MODEL_FALLBACK=gemini

# ── Ollama cloud — gpt-oss:120b ───────────────────────────────────────────────
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=your_ollama_api_key_here     # ollama.com/settings/keys
LLM_MAX_WORKERS_OLLAMA=1
LLM_MAX_CHAR_BUFFER_OLLAMA=30000

# ── Cerebras cloud — gpt-oss-120b ─────────────────────────────────────────────
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_API_KEY=your_cerebras_api_key_here  # cerebras.ai/openai
LLM_MAX_WORKERS_CEREBRAS=1
LLM_MAX_CHAR_BUFFER_CEREBRAS=100000          # 131K ctx → whole invoice in 1 chunk

# ── Gemini 2.5 Flash — fallback ───────────────────────────────────────────────
LANGEXTRACT_API_KEY=your_gemini_api_key_here  # aistudio.google.com/apikey
LLM_MAX_CHAR_BUFFER=4000
LLM_MAX_WORKERS_GEMINI=10

# ── Currency database (JSON array) ────────────────────────────────────────────
CURRENCY_DB_JSON=[{"code":"EUR","name":"Euro"},{"code":"USD","name":"US Dollar"},{"code":"RUB","name":"Russian Ruble"},{"code":"CNY","name":"Chinese Yuan"}]

# ── Database ──────────────────────────────────────────────────────────────────
# Omit DATABASE_URL to use SQLite (development only)
# DATABASE_URL=postgresql://user:password@localhost:5432/doc_extractor

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
